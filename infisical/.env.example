# Infisical self-host instance secrets. Copy to .env and fill in. .env is gitignored.
#
#   ENCRYPTION_KEY: openssl rand -hex 16
#   AUTH_SECRET:    openssl rand -base64 32
#   DB_PASSWORD:    openssl rand -hex 24
ENCRYPTION_KEY=<openssl rand -hex 16>
AUTH_SECRET=<openssl rand -base64 32>
DB_PASSWORD=<openssl rand -hex 24>

# Public URL the instance is reached at (used in links/issuer)
SITE_URL=http://<server-ip>:8080
