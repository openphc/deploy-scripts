cc.mdtlabs.org {
    handle_path /cc/* {
        # UI entry points (/cc/ui and /cc/) map to the app's root index.html.
        # Everything else (styles.css, app.js, /api/*) passes through unchanged.
        @ui path /ui /ui/ /
        rewrite @ui /
        reverse_proxy localhost:8075 {
            header_up Host {host}
            header_up X-Forwarded-For {remote}
            header_up X-Forwarded-Proto https
        }
    }

    handle_path /bap/* {
        reverse_proxy localhost:8076 {
            header_up Host {host}
            header_up X-Forwarded-For {remote}
            header_up X-Forwarded-Proto https
        }
    }

    handle_path /bpp/* {
        reverse_proxy localhost:8077 {
            header_up Host {host}
            header_up X-Forwarded-For {remote}
            header_up X-Forwarded-Proto https
        }
    }
}
