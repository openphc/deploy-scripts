# Copy this file to .env and fill in the actual values before deploying.
# .env is gitignored and will not be committed. NEVER commit real IPs or secrets.

# ---- Infrastructure host ----
# VM_HOST_IP is the host's IP, used for the NetworkPolicy/firewall (VM_HOST_CIDR) — i.e. "where the
# pods are allowed to egress". It is NOT a service endpoint: address each backing service with its
# own POSTGRES_HOST / KAFKA_HOST below (same value today, but they can live on different hosts in a
# future deployment, so don't conflate them with VM_HOST_IP).
VM_HOST_IP=<your-vm-ip>

# CIDR for the network policy (usually VM_HOST_IP/32)
VM_HOST_CIDR=<your-vm-ip>/32

# Per-service host endpoints (k8s pods reach the host-native infra here). Same as VM_HOST_IP in the
# current single-VM setup, but separate so a deployment can point them elsewhere.
POSTGRES_HOST=<your-vm-ip>
KAFKA_HOST=<your-vm-ip>

# Hostname for ingress routing (used to separate UAT/PROD on same cluster).
# This MUST be a real public DNS name pointing at this VM for TLS certs to be issued.
# Leave blank for IP-only / plain-HTTP deployments with no domain.
INGRESS_HOST=<your-hostname>

# Email registered with Let's Encrypt for Traefik TLS certificates (expiry notices).
# Traefik is cluster-global, so use the SAME value in .env.prod and .env (uat).
ACME_EMAIL=<you@example.com>

# ---- External services ----
# OpenHIM core host (IP or DNS) the emitter-adaptor talks to
OPENHIM_CORE_HOST=<openhim-host>
OPENHIM_USERNAME=
OPENHIM_PASSWORD=

# ClickHouse (data-pipeline) host reachable from the cluster — typically the
# docker bridge gateway IP when the pipeline runs as docker containers.
CLICKHOUSE_HOST=<clickhouse-host>
CLICKHOUSE_USER=<clickhouse-user>
CLICKHOUSE_PASSWORD=<clickhouse-password>

# gateway-service CORS allowed origin. Concrete origin only, never "*"
# (e.g. https://app.example.com, or http://<vm-ip> for a no-domain deployment).
GATEWAY_ALLOWED_ORIGINS=<https://your-frontend-origin>

# ---- Application credentials ----
POSTGRES_USER=<db-user>
POSTGRES_PASSWORD=<db-password>
CCE_COLLECTOR_AUTH_TOKEN=<collector-token>
GRAFANA_ADMIN_USER=<grafana-user>
GRAFANA_ADMIN_PASSWORD=<grafana-password>
KEYCLOAK_ADMIN_USER=<keycloak-admin-user>
KEYCLOAK_ADMIN_PASSWORD=<keycloak-admin-password>
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=
