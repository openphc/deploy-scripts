<clickhouse>
    <!-- ClickHouse 26.3 rejects user/profile-level settings (max_memory_usage,
         max_bytes_before_external_group_by, async_insert) at the top level. Disable that strict
         check so the server starts; relocate them into a <profiles> entry in users.xml if you want
         them enforced. -->
    <skip_check_for_incorrect_settings>1</skip_check_for_incorrect_settings>

    <!-- Listen on all IPv4 so the in-container healthcheck (127.0.0.1:8123) and docker-proxy both
         reach it. The image default listens on ::1 only, which fails on IPv6-disabled hosts. -->
    <listen_host>0.0.0.0</listen_host>

    <max_concurrent_queries>100</max_concurrent_queries>
    <max_memory_usage>28000000000</max_memory_usage>
    <max_bytes_before_external_group_by>10000000000</max_bytes_before_external_group_by>

    <merge_tree>
        <max_suspicious_broken_parts>5</max_suspicious_broken_parts>
    </merge_tree>

    <query_log>
        <database>system</database>
        <table>query_log</table>
        <partition_by>toYYYYMM(event_date)</partition_by>
        <flush_interval_milliseconds>7500</flush_interval_milliseconds>
    </query_log>

    <prometheus>
        <endpoint>/metrics</endpoint>
        <port>9363</port>
        <metrics>true</metrics>
        <events>true</events>
        <asynchronous_metrics>true</asynchronous_metrics>
    </prometheus>

    <!-- Kafka-engine ingestion batches via kafka_max_block_size; server-level async inserts with
         wait_for_async_insert=0 risk data loss on crash with no throughput benefit. -->
    <async_insert>0</async_insert>
</clickhouse>
