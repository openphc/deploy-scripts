<clickhouse>
    <!-- The cce_pipeline USER is created by the container entrypoint from CLICKHOUSE_USER /
         CLICKHOUSE_PASSWORD (users.d/default-user.xml). We only attach a grants block to it here.

         IMPORTANT (ClickHouse 26.3):
           * Do NOT redefine the user's password/profile here — merging with the entrypoint's
             definition produces a "more than one field of password" error.
           * A <grants> block is EXCLUSIVE: it defines the user's COMPLETE grant set. So we must
             grant ALL *plus* the cce_kafka named collection, otherwise the user loses its implicit
             full access (and could not create the schema or read the Kafka named collection). -->
    <profiles>
        <!-- Optional read-only profile (auto-FINAL) cce-insights-service can opt into for
             consistent reads of the ReplacingMergeTree tables. -->
        <analytics>
            <final>1</final>
            <max_execution_time>60</max_execution_time>
            <readonly>1</readonly>
        </analytics>
    </profiles>

    <users>
        <cce_pipeline>
            <grants>
                <query>GRANT ALL ON *.*</query>
                <query>GRANT NAMED COLLECTION ON cce_kafka</query>
            </grants>
        </cce_pipeline>
    </users>
</clickhouse>
