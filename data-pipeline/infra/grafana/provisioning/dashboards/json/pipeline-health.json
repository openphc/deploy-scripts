{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Replication Slot Active",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": "PostgreSQL",
      "targets": [
        {
          "rawSql": "SELECT now() AS time, active::int AS slot_active FROM pg_replication_slots WHERE slot_name = 'cce_analytics_slot'",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "text": "INACTIVE", "color": "red" }, "1": { "text": "ACTIVE", "color": "green" } }, "type": "value" }
          ]
        }
      }
    },
    {
      "title": "Inbound Events / min (ClickHouse)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": "ClickHouse",
      "targets": [
        {
          "rawSql": "SELECT toStartOfMinute(received_at) AS time, count() AS events FROM cce_analytics.inbound_event_logs WHERE received_at >= now() - INTERVAL 1 HOUR GROUP BY time ORDER BY time",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "title": "CDC Freshness (s since last event)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": "ClickHouse",
      "targets": [
        {
          "rawSql": "SELECT now() AS time, dateDiff('second', max(received_at), now()) AS seconds_since_last_event FROM cce_analytics.inbound_event_logs",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 120, "color": "yellow" },
              { "value": 600, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "title": "ClickHouse Insert Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(ClickHouseProfileEvents_InsertedRows[5m])",
          "legendFormat": "rows/sec"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    },
    {
      "title": "ClickHouse Queries in Flight",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 16 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "ClickHouseMetrics_Query"
        }
      ]
    },
    {
      "title": "ClickHouse Active Merges",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 16 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "ClickHouseMetrics_Merge"
        }
      ]
    },
    {
      "title": "ClickHouse Disk Usage",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 16 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "ClickHouseAsyncMetrics_DiskUsed_default / ClickHouseAsyncMetrics_DiskTotal_default * 100"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 70, "color": "yellow" },
              { "value": 85, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "title": "CDC End-to-End Latency (commit → ClickHouse)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": "ClickHouse",
      "targets": [
        {
          "rawSql": "SELECT toStartOfMinute(received_at) AS time, quantile(0.5)(dateDiff('second', event_time, received_at)) AS p50, quantile(0.95)(dateDiff('second', event_time, received_at)) AS p95 FROM cce_analytics.inbound_event_logs WHERE received_at >= now() - INTERVAL 1 HOUR AND event_time IS NOT NULL GROUP BY time ORDER BY time",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "CDC Replication Slot Lag",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": "PostgreSQL",
      "targets": [
        {
          "rawSql": "SELECT now() AS time, slot_name, pg_wal_lsn_diff(pg_current_wal_lsn(), confirmed_flush_lsn) AS lag_bytes FROM pg_replication_slots WHERE slot_name LIKE 'cce%'",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      }
    },
    {
      "title": "MergeTree Parts per Table (merge pressure)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 28 },
      "datasource": "ClickHouse",
      "targets": [
        {
          "rawSql": "SELECT now() AS time, table, count() AS active_parts FROM system.parts WHERE database = 'cce_analytics' AND active GROUP BY table ORDER BY active_parts DESC",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["cce", "pipeline", "monitoring"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "CCE Pipeline Health (Dashboard 11)",
  "uid": "cce-pipeline-health",
  "version": 1
}
