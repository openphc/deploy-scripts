# CCE Data Pipeline — Environment Variables
# Copy to .env and fill in actual values

# ClickHouse
CLICKHOUSE_PASSWORD=CHANGE_ME_IN_PRODUCTION

# Kafka (the EXISTING broker on the shared cce-net network — confluentinc/cp-kafka, KRaft).
# Used by the Kafka Connect worker and by the ClickHouse Kafka-engine tables (schema/02).
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# PostgreSQL CDC source (the EXISTING ccedb on cce-net — the Debezium connector reads it).
# CDC_PG_HOST is the in-network service name; CDC_USER needs REPLICATION (cdc/01-...sql).
# These are interpolated into connectors/debezium-postgres-source.json by register-connectors.sh.
CDC_PG_HOST=postgres
CDC_PG_PORT=5432
CDC_PG_DATABASE=ccedb
CDC_USER=cce_cdc_user
CDC_PASSWORD=CHANGE_ME_IN_PRODUCTION

# Kafka Connect REST endpoint (where the Debezium connector is registered)
CONNECT_URL=http://localhost:8083

# ClickHouse connection (for insights-service / clients / scripts) — one canonical CLICKHOUSE_* set.
# (The old host-local CH_HOST/CH_PORT/CH_NATIVE_PORT were unified into these; CLICKHOUSE_HOST is
# reachable from both host-run scripts and in-cluster pods.)
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=cce_analytics
CLICKHOUSE_USER=cce_pipeline
# CLICKHOUSE_PASSWORD is set above

# Presentation layer (cce-insights-service / cce-insights-ui) is a separate deployment on
# cce-net. It connects to ClickHouse using the cce_pipeline user above (HTTP 8123 or native 9000).
#
# Prometheus + Grafana are the platform's existing instances on cce-net — add ClickHouse (9363)
# as a scrape target and import infra/grafana/... there; this repo no longer runs its own.
