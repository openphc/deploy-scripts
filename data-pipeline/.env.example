# CCE Data Pipeline — Environment Variables
# Copy to .env and fill in actual values

# Shared docker network to attach ClickHouse + Kafka Connect to (so they reach the Kafka broker
# and ccedb by name). Default `cce-net` is the network the root docker-compose.yml pins. If your
# infra runs as a separate compose project, set this to that project's network (e.g. RW UAT uses
# `infrastructure_default`) — do NOT stand up a second bridge alongside it.
PIPELINE_NETWORK=cce-net

# ClickHouse
CLICKHOUSE_PASSWORD=CHANGE_ME_IN_PRODUCTION

# Kafka (the EXISTING broker on the shared network — confluentinc/cp-kafka, KRaft).
# Used by the Kafka Connect worker and by the ClickHouse Kafka-engine tables (schema/02).
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# PostgreSQL CDC source (the EXISTING ccedb on the shared network — the Debezium connector reads it).
# POSTGRES_HOST is the in-network service name; POSTGRES_READ_ONLY_USER needs REPLICATION (cdc/01-...sql).
# These are interpolated into connectors/debezium-postgres-source.json by register-connectors.sh.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DATABASE=ccedb
POSTGRES_READ_ONLY_USER=cce_cdc_user
POSTGRES_READ_ONLY_PASSWORD=CHANGE_ME_IN_PRODUCTION

# Kafka Connect REST endpoint (where the Debezium connector is registered)
CONNECT_URL=http://localhost:8083

# ClickHouse connection (for insights-service / clients / scripts) — one canonical CLICKHOUSE_* set.
# (The old host-local CH_HOST/CH_PORT/CH_NATIVE_PORT were unified into these; CLICKHOUSE_HOST is
# reachable from both host-run scripts and in-cluster pods.)
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=cce_analytics
CLICKHOUSE_USER=cce_pipeline
# CLICKHOUSE_PASSWORD is set above

# Presentation layer (cce-insights-service / cce-insights-ui) is a separate deployment on the
# shared network. It connects to ClickHouse using the cce_pipeline user above (HTTP 8123 or native 9000).
#
# Prometheus + Grafana are the platform's existing instances on the shared network — add ClickHouse
# (9363) as a scrape target and import infra/grafana/... there; this repo no longer runs its own.
